{
  "gateway": {
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "controlUi": {
      // TODO: harden
      "allowInsecureAuth": true,
      "allowedOrigins": ["http://192.168.0.6:18789", "http://ubuntu1:18789"],
      "dangerouslyDisableDeviceAuth": true
    },
    "mode": "local",
    "port": 18789,
    "bind": "lan"
  },
  "agents": {
    "defaults": {
      "skipBootstrap": true,
      "model": "litellm/qwen-dense",
      "params": {
        "temperature": 0.6,
        "presence_penalty": 0
      },
      "heartbeat": {
        "every": "30m",
        "lightContext": false,
        "skipWhenBusy": false,
        "isolatedSession": false,
        "includeReasoning": false,
        "activeHours": {
          "start": "09:00",
          "end": "22:00"
        }
      },
      "sandbox": {
        "mode": "all",
        "backend": "ssh",
        "scope": "agent",
        "workspaceAccess": "rw",
        "ssh": {
          "target": "linuxserver.io@openclaw-workspace:2222",
          "workspaceRoot": "/workspace",
          "strictHostKeyChecking": true,
          "updateHostKeys": true,
          "identityFile": "~/.openclaw/.ssh/id_rsa",
          "certificateFile": "~/.openclaw/.ssh/id_rsa.pub",
          "knownHostsFile": "~/.openclaw/.ssh/known_hosts"
        }
      }
    },
    "list": [
      {
        "id": "main",
        "name": "main",
        "workspace": "/home/node/.openclaw/workspace/main",
        "heartbeat": {
          "session": "agent:main:telegram:direct:${TELEGRAM_MITHRAS}",
          "target": "telegram",
          "to": "${TELEGRAM_MITHRAS}"
        }
      },
      {
        "id": "dina",
        "name": "dina",
        "workspace": "/home/node/.openclaw/workspace/dina",
        "tools": {
          "elevated": {
            "enabled": false
          }
        },
        "heartbeat": {
          "session": "agent:dina:telegram:direct:${TELEGRAM_DINA}",
          "target": "telegram",
          "to": "${TELEGRAM_DINA}"
        }
      }
    ]
  },
  "bindings": [
    {
      "agentId": "main",
      "match": { "channel": "telegram", "accountId": "default" }
    },
    {
      "agentId": "dina",
      "match": {
        "channel": "telegram",
        "peer": { "kind": "direct", "id": "${TELEGRAM_DINA}" }
      }
    }
  ],
  "session": {
    "dmScope": "per-channel-peer"
  },
  "tools": {
    "profile": "full",
    "sandbox": {
      "tools": {
        "alsoAllow": [
          "group:memory",
          "group:web"
        ]
      }
    },
    "web": {
      "search": {
        "provider": "searxng",
        "enabled": true
      }
    },
    "elevated": {
      "enabled": true,
      "allowFrom": {
        "telegram": ["${TELEGRAM_MITHRAS}"]
      }
    }
  },
  "plugins": {
    "entries": {
      "litellm": {
        "enabled": true
      },
      "telegram": {
        "enabled": true
      },
      "searxng": {
        "enabled": true,
        "config": {
          "webSearch": {
            "baseUrl": "http://searxng:8080/"
          }
        }
      }
    }
  },
  "models": {
    "providers": {
      "litellm": {
        "baseUrl": "http://litellm:4000",
        "apiKey": "${LITELLM_API_KEY}",
        "api": "openai-completions",
        "auth": "api-key",
        "models": [
          {
            "id": "qwen-dense",
            "name": "qwen-dense",
            "api": "openai-completions",
            "reasoning": false,
            "input": ["text", "image"],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 262144,
            "maxTokens": 65536
          }
        ]
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "groups": {
        "*": {
          "requireMention": true
        }
      },
      "botToken": "${TELEGRAM_BOT_TOKEN}"
    }
  },
  "wizard": {
    "lastRunAt": "2026-05-09T04:21:36.921Z",
    "lastRunVersion": "2026.5.7",
    "lastRunCommand": "onboard",
