// P1: Email
// P1: Community *.md

// P2: skills/tools
//   - Home Assistant
//   - pdf?
//   - rag?
//   - browser?
{
  "gateway": {
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "controlUi": {
      // TODO: harden
      "allowInsecureAuth": true,
      "allowedOrigins": ["http://192.168.0.6:18789", "http://ubuntu1:18789"],
      "dangerouslyDisableDeviceAuth": true
    },
    "mode": "local",
    "port": 18789,
    "bind": "lan"
  },
  "agents": {
    "defaults": {
      "skipBootstrap": true,
      "model": "litellm/qwen-dense",
      "imageModel": "litellm/qwen-moe",
      "subagents": {
        "model": "litellm/qwen-moe"
      },
      "heartbeat": {
        "model": "litellm/qwen-moe",
        "every": "30m",
        "lightContext": false,
        "skipWhenBusy": false,
        "isolatedSession": false,
        "includeReasoning": false,
        "activeHours": {
          "start": "09:00",
          "end": "22:00"
        }
      },
      "sandbox": {
        "mode": "all",
        "backend": "ssh",
        "scope": "agent",
        "workspaceAccess": "rw",
        "ssh": {
          "command": "/home/node/.openclaw/ssh-wrapper.sh",
          "target": "linuxserver.io@openclaw-workspace:2222",
          "workspaceRoot": "/workspace",
          "strictHostKeyChecking": false,
          "updateHostKeys": true,
          "identityFile": "~/.openclaw/.ssh/id_rsa",
          "certificateFile": "~/.openclaw/.ssh/id_rsa.pub",
          "knownHostsFile": "~/.openclaw/.ssh/known_hosts"
        },
        "prune": {
          "idleHours": 0,
          "maxAgeDays": 0
        }
      },
      // openclaw memory index --force --agent main
      // openclaw memory status --deep --agent main
      "memorySearch": {
        "provider": "openai",
        "model": "qwen-embedding",
        "remote": {
          "baseUrl": "http://litellm:4000",
          "apiKey": "${LITELLM_API_KEY}"
        },
        "query": {
          "hybrid": {
            "mmr": {
              "enabled": true
            },
            "temporalDecay": {
              "enabled": true
            }
          }
        },
        "extraPaths": ["obsidian"]
      }
    },
    "list": [
      {
        "id": "main",
        "name": "main",
        "workspace": "/home/node/.openclaw/workspace/main",
        "tools": {
          "sandbox": {
            "tools": {
              "alsoAllow": ["gateway"]
            }
          }
        },
        "heartbeat": {
          "session": "agent:main:telegram:direct:${TELEGRAM_MITHRAS}",
          "target": "telegram",
          "to": "${TELEGRAM_MITHRAS}"
        }
      },
      {
        "id": "dina",
        "name": "dina",
        "workspace": "/home/node/.openclaw/workspace/dina",
        "tools": {
          "elevated": {
            "enabled": false
          }
        },
        "heartbeat": {
          "session": "agent:dina:telegram:direct:${TELEGRAM_DINA}",
          "target": "telegram",
          "to": "${TELEGRAM_DINA}"
        }
      }
    ]
  },
  "bindings": [
    {
      "agentId": "main",
      "match": {
        "channel": "telegram",
        "peer": {
          "kind": "direct",
          "id": "${TELEGRAM_MITHRAS}"
        }
      }
    },
    {
      "agentId": "main",
      "match": {
        "channel": "telegram",
        "peer": {
          "kind": "group",
          "id": "-1003720615070"
        }
      }
    },
    {
      "agentId": "dina",
      "match": {
        "channel": "telegram",
        "peer": {
          "kind": "direct",
          "id": "${TELEGRAM_DINA}"
        }
      }
    },
    {
      "agentId": "dina",
      "match": {
        "channel": "telegram",
        "peer": {
          "kind": "group",
          "id": "-1003945418098"
        }
      }
    }
  ],
  "session": {
    "dmScope": "per-channel-peer",
    "reset": {
      "mode": "idle",
      "idleMinutes": 10080 // 1 week
    }
  },
  "commitments": {
    "enabled": true
  },
  "tools": {
    "profile": "full",
    "sandbox": {
      "tools": {
        // openclaw sandbox explain --agent main
        "allow": [
          "exec",
          "process",
          "group:fs", // "read", "write", "edit", "apply_patch"
          "group:sessions", // "sessions_list", "sessions_history", "sessions_send", "sessions_spawn", "sessions_yield", "subagents", "session_status"
          "group:memory", // "memory_search", "memory_get"
          "group:web", // "web_search", "x_search", "web_fetch"
          "group:messaging", // "message"
          "cron",
          "image",
          "lcm_grep",
          "lcm_describe",
          "lcm_expand_query"
        ]
      }
    },
    "web": {
      "search": {
        "provider": "searxng",
        "enabled": true
      }
    },
    "elevated": {
      "enabled": true,
      "allowFrom": {
        "telegram": ["${TELEGRAM_MITHRAS}"]
      }
    },
    "media": {
      "audio": {
        "enabled": true,
        "echoTranscript": true,
        "models": [
          {
            "provider": "openai",
            "model": "distil-whisper/distil-large-v3.5-ct2"
          }
        ]
      }
    }
  },
  "plugins": {
    "slots": {
      "contextEngine": "lossless-claw"
    },
    "entries": {
      "litellm": {
        "enabled": true
      },
      "telegram": {
        "enabled": true
      },
      "searxng": {
        "enabled": true,
        "config": {
          "webSearch": {
            "baseUrl": "http://searxng:8080/"
          }
        }
      },
      // openclaw plugins update @martian-engineering/lossless-claw
      "lossless-claw": {
        "enabled": true,
        "config": {
          "summaryModel": "litellm/qwen-moe",
          "largeFileSummaryModel": "litellm/qwen-moe",
          "expansionModel": "litellm/qwen-moe",
          "ignoreSessionPatterns": ["agent:*:cron:**"],
          "statelessSessionPatterns": ["agent:*:subagent:**"],
          "skipStatelessSessions": true
        },
        "llm": {
          "allowModelOverride": true,
          "allowedModels": ["litellm/qwen-moe"]
        }
      },
      "active-memory": {
        "enabled": true,
        "config": {
          "enabled": true,
          "model": "litellm/qwen-moe",
          "agents": ["main", "dina"],
          "queryMode": "recent",
          "toolsAllow": [
            "memory_search",
            "memory_get"
            // "lcm_grep",
            // "lcm_describe",
            // "lcm_expand_query"
          ],
          // "promptAppend": "Use LCM tools for recall:\n1. `lcm_grep` — Search all conversations by keyword/regex. Prefer `mode: \"full_text\"` for short topic terms, use `mode: \"regex\"` for alternation or other regex syntax, quote exact phrases, use `sort: \"relevance\"` for older-topic lookups, and `sort: \"hybrid\"` when recency should still matter.\n2. `lcm_describe` — Inspect a specific summary (cheap, no sub-agent)\n3. `lcm_expand_query` — Deep recall with bounded sub-agent expansion\n\nWhen summaries in context have an \"Expand for details about:\" footer listing something you need, use `lcm_expand_query` to get the full detail.",
          "timeoutMs": 15000,
          "setupGraceTimeoutMs": 15000,
          "logging": true
        }
      },
      "memory-core": {
        "config": {
          "dreaming": {
            "enabled": true,
            "model": "litellm/qwen-moe"
          }
        },
        "subagent": {
          "allowModelOverride": true,
          "allowedModels": ["litellm/qwen-moe"]
        }
      }
    }
  },
  "messages": {
    "tts": {
      "auto": "inbound",
      "provider": "openai",
      "summaryModel": "litellm/qwen-moe",
      "modelOverrides": {
        "enabled": true
      },
      "providers": {
        "openai": {
          "apiKey": "na",
          "model": "speaches-ai/Kokoro-82M-v1.0-ONNX",
          "baseUrl": "http://192.168.0.2:8001/v1",
          "voice": "af_heart",
          "responseFormat": "mp3"
        }
      }
    }
  },
  "models": {
    "providers": {
      "litellm": {
        "baseUrl": "http://litellm:4000",
        "apiKey": "${LITELLM_API_KEY}",
        "api": "openai-completions",
        "auth": "api-key",
        "request": {
          "allowPrivateNetwork": true
        },
        "models": [
          {
            "id": "qwen-dense",
            "name": "qwen-dense",
            "api": "openai-completions",
            "reasoning": true,
            "input": ["text", "image"],
            "contextWindow": 150000,
            "maxTokens": 65536,
            "params": {
              "temperature": 0.6,
              "presence_penalty": 0
            }
          },
          {
            "id": "qwen-moe",
            "name": "qwen-moe",
            "api": "openai-completions",
            "reasoning": true,
            "input": ["text", "image"],
            "contextWindow": 262144,
            "maxTokens": 65536,
            "params": {
              "temperature": 0.6,
              "presence_penalty": 0
            }
          }
        ]
      },
      "openai": {
        "baseUrl": "http://192.168.0.2:8001/v1",
        "apiKey": "na",
        "request": {
          "allowPrivateNetwork": true
        },
        "models": [
          {
            "id": "distil-whisper/distil-large-v3.5-ct2",
            "name": "distil-whisper/distil-large-v3.5-ct2"
          },
          {
            "id": "speaches-ai/Kokoro-82M-v1.0-ONNX",
            "name": "speaches-ai/Kokoro-82M-v1.0-ONNX"
          }
        ]
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "allowFrom": ["${TELEGRAM_MITHRAS}", "${TELEGRAM_DINA}"],

      "groupPolicy": "allowlist",
      "groupAllowFrom": ["${TELEGRAM_MITHRAS}", "${TELEGRAM_DINA}"],
      "groups": {
        "-1003720615070": {
          "enabled": true,
          "requireMention": false,
          "allowFrom": ["${TELEGRAM_MITHRAS}"],
          "topics": {
            // "xxx": {
            //   "agentId": "xxx"
            // }
          }
        },
        "-1003945418098": {
          "enabled": true,
          "requireMention": false,
          "allowFrom": ["${TELEGRAM_DINA}"],
          "topics": {}
        }
      },
      "botToken": "${TELEGRAM_BOT_TOKEN}"
    }
  },
  "wizard": {
    "lastRunAt": "2026-05-09T04:21:36.921Z",
